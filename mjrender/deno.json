{
  "name": "mjrender",
  "version": "0.1.0",
  "exports": "./src/cli.ts",
  "tasks": {
    "render": "deno run --allow-read --allow-write --allow-net=tenhou.net src/cli.ts",
    "eval": "deno run --allow-read --allow-net=tenhou.net src/eval.ts",
    "check": "deno check src/*.ts",
    "test": "deno test --allow-read --allow-write --allow-run=deno",
    "bundle": "deno bundle --minify -o mcp.mjs src/mcp.ts && deno compile --allow-read --allow-write --allow-env=HOME --allow-net=tenhou.net --output bundle/server/mjrender-mcp mcp.mjs && deno run -A npm:@anthropic-ai/mcpb pack bundle mjrender.mcpb"
  },
  "imports": {
    "fast-xml-parser": "npm:fast-xml-parser@^4.5.0",
    "@modelcontextprotocol/sdk/": "npm:/@modelcontextprotocol/sdk@^1.12.0/",
    "zod": "npm:zod@^3.24.0"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true
  }
}
